@prefix : <urn:example:> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< << :a :b :c >> :d :e >> :p :o .

{
    ?Y u:subject :a ;
       u:predicate :b ;
       u:object :c ;
       u:subjectLexical   "<urn:example:a>" ;
       u:predicateLexical "<urn:example:b>" ;
       u:objectLexical    "<urn:example:c>" .

    ?X u:subject ?Y ;
       u:predicate :d ;
       u:object :e ;
       u:predicateLexical "<urn:example:d>" ;
       u:objectLexical    "<urn:example:e>" .

    ?X :p :o .   
}
=>
{
    :test :is true .
} .
