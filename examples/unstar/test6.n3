@prefix : <urn:example:> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< << :a :b :c >> :d :e >> :p :o .

{
    ?S u:subject :s ;
       u:predicate :p ;
       u:object :o ;
       u:subjectLexical   "<urn:example:s>" ;
       u:predicateLexical "<urn:example:p>" ;
       u:objectLexical    "<urn:example:o>" .
    ?S :p :o .   
}
=>
{
    :test :is true .
} .
