@prefix : <urn:example:> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< _:s :p :o >> :p :o .

{
    ?S u:subject ?Blank ;
       u:predicate :p ;
       u:object :o ;
       u:predicateLexical "<urn:example:p>" ;
       u:objectLexical    "<urn:example:o>" .
    ?S :p :o .   
}
=>
{
    :test :is true .
} .
