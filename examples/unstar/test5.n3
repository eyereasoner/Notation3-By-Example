@prefix : <http://example.org/> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< _:s :p :o >> :p :o .

{
    ?S u:subject ?Blank ;
       u:predicate :p ;
       u:object :o ;
       u:predicateLexical "<http://example.org/p>" ;
       u:objectLexical    "<http://example.org/o>" .
    ?S :p :o .   
}
=>
{
    :test5 :is true .
} .
