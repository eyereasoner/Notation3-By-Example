@prefix : <http://example.org/> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< :a :b :c >> :p :o .
<< :a :b :c >> :p :o2 .

{
    ?S1 u:subject :a ;
       u:predicate :b ;
       u:object :c ;
       u:subjectLexical   "<http://example.org/a>" ;
       u:predicateLexical "<http://example.org/b>" ;
       u:objectLexical    "<http://example.org/c>" .
    ?S1 :p :o .   

    ?S2 u:subject :a ;
       u:predicate :b ;
       u:object :c ;
       u:subjectLexical   "<http://example.org/a>" ;
       u:predicateLexical "<http://example.org/b>" ;
       u:objectLexical    "<http://example.org/c>" .
    ?S2 :p :o2 .   
}
=>
{
    :test3 :is true .
} .
