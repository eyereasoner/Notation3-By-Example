@prefix : <urn:example:> .
@prefix u: <https://w3c.github.io/rdf-star/unstar#> .

<< :a :b :c >> :p :o .
<< :a :b :c >> :p :o2 .

{
    ?S1 u:subject :a ;
       u:predicate :b ;
       u:object :c ;
       u:subjectLexical   "<urn:example:a>" ;
       u:predicateLexical "<urn:example:b>" ;
       u:objectLexical    "<urn:example:c>" .
    ?S1 :p :o .   

    ?S2 u:subject :a ;
       u:predicate :b ;
       u:object :c ;
       u:subjectLexical   "<urn:example:a>" ;
       u:predicateLexical "<urn:example:b>" ;
       u:objectLexical    "<urn:example:c>" .
    ?S2 :p :o2 .   
}
=>
{
    :test :is true .
} .
